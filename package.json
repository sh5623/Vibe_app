{
  "name": "vibe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "check": "biome check --write . && pnpm run check:tw",
    "check:tw": "! grep -rE 'bg-gradient-to-|flex-shrink-0|flex-grow-0|@tailwind base|@tailwind components|@tailwind utilities' app/ --include='*.tsx' --include='*.ts' --include='*.css' 2>/dev/null",
    "typecheck": "react-router typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@react-router/node": "^7.18.0",
    "@react-router/serve": "^7.18.0",
    "@tanstack/react-query": "^5.101.0",
    "framer-motion": "^12.40.0",
    "googleapis": "^173.0.0",
    "lucide-react": "^0.576.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.18.0",
    "recharts": "^3.8.1",
    "yahoo-finance2": "^3.15.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14",
    "isbot": "^5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.61.0",
    "@react-router/dev": "^7.18.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
