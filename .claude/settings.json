{
  "permissions": {
    "allow": [
      "Bash(yarn dev)",
      "Bash(yarn build)",
      "Bash(yarn lint)",
      "Bash(yarn lint --fix)",
      "Bash(yarn start)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)"
    ]
